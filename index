<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>For Kak Deyan ❤️</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Poppins', sans-serif;
}

body {
  height: 100vh;
  background: linear-gradient(135deg, #ffdde1, #ee9ca7);
  overflow: hidden;
}

/* OPENING SCREEN */
.opening {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  color: white;
  z-index: 5;
}

button {
  padding: 14px 28px;
  border: none;
  border-radius: 30px;
  background: white;
  color: #ee9ca7;
  font-weight: bold;
  cursor: pointer;
  margin-top: 20px;
  transition: 0.3s;
}

button:hover {
  transform: scale(1.1);
}

/* CARD */
.card {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 90%;
  max-width: 420px;
  padding: 28px;
  border-radius: 28px;
  text-align: center;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(15px);
  color: white;
  opacity: 0;
  transition: 1s;
}

.card.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

h1 {
  margin-bottom: 15px;
}

p {
  font-size: 14px;
  line-height: 1.7;
}

.highlight {
  font-weight: bold;
}

/* HEARTS */
.heart {
  position: absolute;
  color: rgba(255,255,255,0.4);
  animation: float 6s linear infinite;
}

@keyframes float {
  from {
    transform: translateY(100vh);
    opacity: 0;
  }
  20% {
    opacity: 1;
  }
  to {
    transform: translateY(-100px);
    opacity: 0;
  }
}

/* GLOW EFFECT */
.card::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 28px;
  box-shadow: 0 0 40px rgba(255,255,255,0.3);
  z-index: -1;
}
</style>
</head>

<body>

<!-- OPENING -->
<div class="opening" id="opening">
  <h2>Ada sesuatu buat kakak...</h2>
  <button onclick="start()">Klik ya ❤️</button>
</div>

<!-- CARD -->
<div class="card" id="card">
  <h1>Untuk Kak Deyan ❤️</h1>

  <p>
    aku ga pernah nyangka bakal sejauh ini sama seseorang...<br><br>

    aku yang biasanya selalu siap ditinggal,<br>
    sekarang malah takut kehilangan satu orang yang sama.<br><br>

    dan orang itu... kakak.<br><br>

    kakak bukan cuma bikin aku seneng,<br>
    tapi bikin aku ngerasa pulang.<br><br>

    <span class="highlight">
      kalau suatu hari dunia lagi berat,<br>
      aku cuma pengen kakak inget satu hal:<br><br>

      aku tetap milih kakak.<br>
      berkali-kali.<br>
      tanpa ragu.<br><br>

      bahkan di versi hidup aku yang lain.
    </span>
  </p>
</div>

<!-- MUSIC -->
<audio id="music" loop>
  <source src="lagu.mp3" type="audio/mpeg">
</audio>

<!-- HEARTS -->
<script>
function start() {
  document.getElementById("opening").style.display = "none";
  document.getElementById("card").classList.add("show");

  document.getElementById("music").play();

  createHearts();
}

function createHearts() {
  for (let i = 0; i < 20; i++) {
    let heart = document.createElement("div");
    heart.className = "heart";
    heart.innerHTML = "❤";

    heart.style.left = Math.random() * 100 + "%";
    heart.style.fontSize = (15 + Math.random() * 20) + "px";
    heart.style.animationDuration = (4 + Math.random() * 4) + "s";

    document.body.appendChild(heart);
  }
}
</script>

</body>
</html>
